---
import Layout from '../../../layouts/Layout.astro';
import { db } from '../../../services/db';

export const prerender = false;

const user = Astro.locals.user;
if (!user || (user.role !== 'admin' && user.role !== 'teacher')) {
  return Astro.redirect('/dashboard');
}

let errMsg = '';

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const title = (formData.get('title') as string)?.trim();
    const slug = (formData.get('slug') as string)?.trim();
    const summary = (formData.get('summary') as string)?.trim();
    const cover_url = (formData.get('cover_url') as string)?.trim();
    const content = (formData.get('content') as string)?.trim();

    if (!title || !slug || !content) {
      throw new Error('Tiêu đề, Slug và Nội dung là bắt buộc.');
    }

    await db.createBlog({
      title, slug, summary: summary || null, cover_url: cover_url || null, content,
      created_by: user.id
    });

    return Astro.redirect('/admin/blogs');
  } catch (err: any) {
    errMsg = err.message || 'Lỗi tạo bài viết.';
  }
}
---

<Layout title="Tạo bài viết mới">
  <div class="max-w-3xl mx-auto space-y-6">
    <div>
      <a href="/admin/blogs" class="inline-flex items-center text-xs font-bold text-gray-400 hover:text-gray-600 dark:hover:text-slate-350 transition-colors uppercase tracking-wider mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        Quản lý Blog
      </a>
      <h1 class="text-2xl md:text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight">Tạo bài viết mới</h1>
    </div>

    {errMsg && (
      <div class="p-4 rounded-xl bg-rose-50 text-rose-600 text-sm font-semibold border border-rose-100 dark:bg-rose-950/20 dark:text-rose-400 dark:border-rose-900/35">
        {errMsg}
      </div>
    )}

    <form method="POST" class="bg-white dark:bg-slate-900 border border-gray-250 dark:border-slate-800/80 rounded-2xl p-6 md:p-8 space-y-5 shadow-sm">
      <div>
        <label for="title" class="block text-xs font-bold text-gray-500 dark:text-slate-400 uppercase tracking-wider mb-1.5">Tiêu đề *</label>
        <input type="text" id="title" name="title" required
          class="w-full px-4 py-3 rounded-xl border border-gray-250 dark:border-slate-800/80 bg-transparent text-sm focus:border-blue-500 outline-none text-gray-800 dark:text-slate-100 transition-colors"
          placeholder="Bí kíp đạt điểm 9+..." />
      </div>

      <div>
        <label for="slug" class="block text-xs font-bold text-gray-500 dark:text-slate-400 uppercase tracking-wider mb-1.5">Slug *</label>
        <input type="text" id="slug" name="slug" required
          class="w-full px-4 py-3 rounded-xl border border-gray-250 dark:border-slate-800/80 bg-transparent text-sm focus:border-blue-500 outline-none text-gray-800 dark:text-slate-100 transition-colors font-mono"
          placeholder="bi-kip-dat-diem-9..." />
      </div>

      <div>
        <label for="summary" class="block text-xs font-bold text-gray-500 dark:text-slate-400 uppercase tracking-wider mb-1.5">Mô tả ngắn</label>
        <textarea id="summary" name="summary" rows="2"
          class="w-full px-4 py-3 rounded-xl border border-gray-250 dark:border-slate-800/80 bg-transparent text-sm focus:border-blue-500 outline-none text-gray-800 dark:text-slate-100 transition-colors"
          placeholder="Tóm tắt nội dung bài viết..."></textarea>
      </div>

      <div>
        <label for="cover_url" class="block text-xs font-bold text-gray-500 dark:text-slate-400 uppercase tracking-wider mb-1.5">URL ảnh bìa</label>
        <input type="url" id="cover_url" name="cover_url"
          class="w-full px-4 py-3 rounded-xl border border-gray-250 dark:border-slate-800/80 bg-transparent text-sm focus:border-blue-500 outline-none text-gray-800 dark:text-slate-100 transition-colors"
          placeholder="https://images.unsplash.com/..." />
      </div>

      <div>
        <label for="content" class="block text-xs font-bold text-gray-500 dark:text-slate-400 uppercase tracking-wider mb-1.5">Nội dung (Markdown) *</label>
        <textarea id="content" name="content" rows="16" required
          class="w-full px-4 py-3 rounded-xl border border-gray-250 dark:border-slate-800/80 bg-transparent text-sm focus:border-blue-500 outline-none text-gray-800 dark:text-slate-100 transition-colors font-mono"
          placeholder="# Tiêu đề bài viết&#10;&#10;Nội dung bài viết..."></textarea>
      </div>

      <div class="flex justify-end gap-3 pt-4">
        <a href="/admin/blogs"
          class="px-6 py-3 rounded-xl border border-gray-250 dark:border-slate-800 text-sm font-semibold text-gray-700 dark:text-slate-300 hover:bg-gray-50 dark:hover:bg-slate-800 transition">
          Hủy
        </a>
        <button type="submit"
          class="px-6 py-3 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-bold text-sm shadow shadow-blue-500/15 transition">
          Tạo bài viết
        </button>
      </div>
    </form>
  </div>
</Layout>